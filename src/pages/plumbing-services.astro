---
import { getEntry } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import { createServiceListSchema } from '../lib/schema/factories';
import { getCollection } from 'astro:content';
import { sortByPositionThenTitle } from '../lib/sortByPositionThenTitle';

const page = await getEntry('pages', 'plumbing-services');

if (!page) {
  throw new Error('Plumbing Services page content not found');
}

// City names to exclude from general services list
const cityNames = ['santa-rosa', 'petaluma', 'novato', 'san-rafael', 'healdsburg', 'sonoma', 'mill-valley'];

// Filter to only general services (exclude city-specific pages)
const services = await getCollection('services', ({ slug, data }) => {
  if (data.draft) return false;
  return !cityNames.some(city => slug.includes(city));
});

const sortedServices = sortByPositionThenTitle(
  services,
  service => service.data.position,
  service => service.data.name || service.data.menuText || service.data.linkText || service.data.title
);

const serviceDetails = sortedServices.map(service => ({
  slug: service.slug,
  name: service.data.name || service.data.title,
  description: service.data.description || '',
  position: service.data.position,
  offers: service.data.offers?.map(offer => ({
    name: offer.name,
    description: offer.description
  }))
}));

const { Content } = await page.render();
const schema = await createServiceListSchema(serviceDetails);

---

<PageLayout page={{ ...page, data: { ...page.data, schema } }}>
  <Content />
</PageLayout>
