---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProcessStepper from '../components/ProcessStepper.astro';
import CompanyName from '../components/CompanyName.astro';
import { createHomePageSchemas } from '../lib/schema/factories';
import { Flame, ShowerHead, Droplets, Bath, Siren, ArrowRight } from '@lucide/astro';
import '../styles/pages/index.css';

// Homepage gets WebSite + WebPage schemas
const homePageSchemas = await createHomePageSchemas();

---

<BaseLayout
  title="GOFLOW Plumbing | Plumbing Services in Sonoma County & Marin County"
  description="3rd generation plumbers serving Sonoma County & Marin County. Water heater repair, drain cleaning, leak detection & 24/7 emergency service. Call (707) 200-8350."
  schema={homePageSchemas}
>
  <div>

    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-container">
        <h1><CompanyName full /></h1>
        <h2>3rd Generation Experts</h2>
        <!-- Problem Selector -->
        <div class="problems">
          <div class="problems-container">
            <h2 id="problems-headline">Which Plumbing Problem of Yours Do We Get to Fix?</h2>
            <div class="problems-grid">
              <a href="/water-heater-repair-and-replacement/" class="problem-tile">
                <Flame class="problem-icon" aria-hidden="true" />
                <span class="problem-text">No hot water</span>
              </a>
              <a href="/clogged-drains-rootered/" class="problem-tile">
                <ShowerHead class="problem-icon" aria-hidden="true" />
                <span class="problem-text">Drain clogged</span>
              </a>
              <a href="/leak-detection-and-repair/" class="problem-tile">
                <Droplets class="problem-icon" aria-hidden="true" />
                <span class="problem-text">Leak</span>
              </a>
              <a href="/clogged-or-running-toilets/" class="problem-tile">
                <Bath class="problem-icon" aria-hidden="true" />
                <span class="problem-text">Toilet issue</span>
              </a>
              <a href="/emergency-plumbing-services/" class="problem-tile problem-tile-emergency">
                <Siren class="problem-icon" aria-hidden="true" />
                <span class="problem-text">Emergency</span>
              </a>
              <a href="/plumbing-services/" class="problem-tile problem-tile-all">
                <ArrowRight class="problem-icon" aria-hidden="true" />
                <span class="problem-text">All services</span>
              </a>
            </div>
          </div>
        </div>
        <div class="space-x-4">
          <a href="/contact-us/" class="btn btn-primary">Contact Us</a>
          <a href="/plumbing-services/" class="btn btn-secondary">Our Services</a>
        </div>
      </div>
    </section>

    <!-- <div class="hero-text">
      <p>
        GOFLOW Plumbing are your Sonoma County and Marin County third generation plumbers.
        Make your plumbing problem ours — we'll treat your home better than our own mom's.<br />
        Sorry, mom.
      </p>
    </div> -->
    <!-- GOFLOW RESERVE Promo -->
    <section class="reserve-promo">
      <div class="reserve-promo-container">
        <h2>Gas Water Heaters Are Being Banned in 2027</h2>
        <p class="promo-text">
          Don't get stuck paying $10,000+ for a heat pump conversion. 
          <span class="brand-name glow">GOFLOW RESERVE</span> lets you lock in a pre-2027 
          gas water heater now—and install it when you need it.
        </p>
        <div class="promo-highlights">
          <span>$999 reservation</span>
          <span>$3,999 installation</span>
          <span>10-year flexibility</span>
        </div>
        <a href="/reserve/" class="btn btn-accent">Reserve My Water Heater Now</a>
        <p class="countdown"></p>
      </div>
    </section>

    <script>
      import { initCountdown } from '../scripts/countdown';
      initCountdown();
    </script>

    <!-- Process Stepper - Extreme Communication -->
    <ProcessStepper />

    <!-- Customer Reviews -->
    <section class="reviews">
      <div>
        <h2>What Our Customers Say</h2>
        <div class="reviews-grid">
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Shaun S.</span>
              <span class="review-date">Jun 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">We have been in our San Anselmo home for 45 years and have done major remodels and countless simple home repairs. Hands down Chris at Goflow was the best plumbing contractor we've used and I know them all. We required a full water supply line replacement that was a challenging project. He was knowledgeable, persistent, and hardworking...and the pricing was very reasonable. Highly recommend.</p>
            <a href="https://www.yelp.com/biz/goflow-plumbing-sonoma" class="review-source" target="_blank" rel="noopener noreferrer">Yelp</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Joseph Denning</span>
              <span class="review-date">Jun 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">Adam and his crew took care of a stubborn leak that multiple other companies could not handle. Shout out to him and his crew for their expertise in assessing the problem and quickly resolving it. Couldn't recommend these guys enough!!!</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Roberto Saldana</span>
              <span class="review-date">Jun 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">Go flow Plumbing was very professional and easy to work with they were fast, reliable and had very fair pricing!</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Daniel G.</span>
              <span class="review-date">May 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">Super professional! Very kind! Helped me with installing a reverse osmosis water machine and a new kitchen faucet. They guys are great!</p>
            <a href="https://www.yelp.com/biz/goflow-plumbing-sonoma" class="review-source" target="_blank" rel="noopener noreferrer">Yelp</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Danny Geren, L.Ac.</span>
              <span class="review-date">May 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">This team was super kind and accommodating! They did a great job with a faucet replacement and installation of a new reverse osmosis water filter. I highly recommend them!</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Marcie E.</span>
              <span class="review-date">May 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">Fantastic experience. They got back to me immediately on my request and was able to come the next morning. Chris took care of both of my issues very quickly and was lovely to deal with. I would happily recommend them and we'll plan to use go flow in the future.</p>
            <a href="https://www.thumbtack.com/ca/rohnert-park/plumbing/goflow-plumbing/service/441teleN7lYknKM" class="review-source" target="_blank" rel="noopener noreferrer">Thumbtack</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Tara L.</span>
              <span class="review-date">May 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">Adam was very helpful with scheduling and communication. Chris gave us great information and was able to get our job done quickly! Everything looks and works great! Thank you, both! We'll call again for our next plumbing need.</p>
            <a href="https://www.thumbtack.com/ca/rohnert-park/plumbing/goflow-plumbing/service/441teleN7lYknKM" class="review-source" target="_blank" rel="noopener noreferrer">Thumbtack</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Mitesh P.</span>
              <span class="review-date">Apr 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">Timely, responsive, professional. Fair pricing. All good things to say and would hire again. Thanks guys!</p>
            <a href="https://www.thumbtack.com/ca/rohnert-park/plumbing/goflow-plumbing/service/441teleN7lYknKM" class="review-source" target="_blank" rel="noopener noreferrer">Thumbtack</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Kim F.</span>
              <span class="review-date">Apr 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">Chris, with GOFLOW Plumbing has helped me over the past few years with indoor plumbing, outdoor pipe issues and he replaced my water heater. Chris is very professional, honest and reliable. I highly recommend GOFLOW Plumbing.</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Sofia McKnight</span>
              <span class="review-date">Apr 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">It was my first time using GOFLOW and I am so impressed. On time, pleasant and professional. Chris got my drain unclogged and repaired my shower handle at a very reasonable price. I'm sure I will be calling them again!</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Marcus Hernandez</span>
              <span class="review-date">Apr 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">GOFLOW Plumbing has helped us at Empower Building Solutions with the plumbing for a few bathroom remodel projects we have completed. One being in Sonoma and the other in Marin County. Every time they have been responsive, professional, and complete quality work. We will definitely use them again and would recommend them to anyone looking for a quality plumbing company.</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Crystal Bowen</span>
              <span class="review-date">Apr 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">GoFlo Plumbing is our family's highly recommended plumber in Cotati and Sonoma County area. Chris was professional, efficient, great communication and intelligent. Chris came up with solution's to get our newly remodeled bathroom not only working properly with new fixtures, but resolving old plumbing issues and completing quickly with very clean, solid work. Confidently can say our bath and shower will keep flowing and we can sleep good at night knowing there will be no leaks flowing in the future. Thank you GoFlo team! Crystal & Family</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Barbara Norman</span>
              <span class="review-date">Mar 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">I can't say enough good things about these guys! My water heater started leaking Thursday night—right before family were to arrive for the weekend. I was panicking but they got someone out to my place in Oakmont first thing Friday. I had a brand new water heater before they arrived. Seriously saved my weekend! Chris was super professional and explained everything he was doing. I'm so grateful they were able to squeeze me in on such short notice. Thank you thank you thank you!!</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Kyle P.</span>
              <span class="review-date">Mar 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">I got a great deal and everything fixed in a timely manner. I couldn't have asked for a better plumbing service. Chris, who I believe is the owner, was very friendly and professional. I would definitely recommend this company for any first time customers as you will find the only plumber you need to call.</p>
            <a href="https://www.yelp.com/biz/goflow-plumbing-sonoma?hrid=BzmZ6qxYL94ZYLDt7kDkiw" class="review-source" target="_blank" rel="noopener noreferrer">Yelp</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Mark K.</span>
              <span class="review-date">Mar 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">I thought I had a crimped water line requiring trenching. Chris came out and determined the pressure valve needed cleaning. He didn't even push a replacement. Water flow in the house is now fantastic.</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Jason B.</span>
              <span class="review-date">Mar 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">Great experience with GOFLOW Plumbing. They do high-quality work and stand behind everything they do. Chris was super easy to work with and made the whole job stress-free. I'll be using them again for sure.</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Karen T.</span>
              <span class="review-date">Mar 2026</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">I am really happy with the service I received from GOFLOW Plumbing. Chris was great to work with and everything turned out perfectly.</p>
            <a href="https://www.google.com/search?q=goflow+plumbing#lrd=0x21ccd84811445dd1:0xbc645b3c34cce840,1,,,," class="review-source" target="_blank" rel="noopener noreferrer">Google</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Christina Danner</span>
              <span class="review-date">Sep 2025</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="review-text">Great communication, thorough work, highly recommend!</p>
            <a href="https://www.facebook.com/goflow.plumbing.usa/reviews" class="review-source" target="_blank" rel="noopener noreferrer">Facebook</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Kip B.</span>
              <span class="review-date">Oct 2024</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <div class="review-service">Water Heater Installation and Replacement</div>
            <p class="review-text">Chris knows what he's doing, is very conscientious and takes all the time necessary to get the job done right. His prices are the most reasonable I've found. He's my new plumber, highly recommended.</p>
            <a href="https://www.angi.com/companylist/us/ca/rohnert-park/chris-torres-plumbing-reviews-1.htm#reviews" class="review-source" target="_blank" rel="noopener noreferrer">Angi [Chris Torres Plumbing]</a>
          </div>
          <div class="review-card">
            <div class="review-header">
              <span class="reviewer-name">Bert P.</span>
              <span class="review-date">Sep 2024</span>
            </div>
            <div class="review-rating" role="img" aria-label="5 out of 5 stars">★★★★★</div>
            <div class="review-service">Water Heater Installation and Replacement</div>
            <p class="review-text">Chris was prompt to reply to your texts. Chris was conscientious about letting you know he was going to be a little late and why. He was very polite, clean and organized. The job was completed faster than I expected. I am extremely pleased with his work and will highly recommend him. Would not hesitate to used him again. He also had a very competitive price.</p>
            <a href="https://www.angi.com/companylist/us/ca/rohnert-park/chris-torres-plumbing-reviews-1.htm#reviews" class="review-source" target="_blank" rel="noopener noreferrer">Angi [Chris Torres Plumbing]</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="choose-us">
      <div>
        <h2>Why Homeowners Choose <CompanyName full /></h2>
        <div>
          <div>
            <h3>24/7 Emergency Service</h3>
            <p>Available around the clock for all your plumbing emergencies</p>
          </div>
          <div>
            <h3>Licensed & Insured</h3>
            <p>Professional, experienced, and fully certified plumbers</p>
          </div>
          <div>
            <h3>Fair & Honest Pricing</h3>
            <p>Transparent pricing with no hidden fees or surprises</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Service Areas -->
    <section class="service-areas">
      <div>
        <h2><CompanyName full /> Service Areas</h2>
        <p class="section-intro"><CompanyName full /> proudly serves homeowners throughout the North Bay. Whether you're in wine country or near the coast, we're your local plumbing experts.</p>
        <div>
          <div>
            <a href="/sonoma-county-plumbing/">
              <h3>Sonoma County Plumbing</h3>
              <p>Santa Rosa, Petaluma, Healdsburg, Sonoma, and surrounding communities. <CompanyName full /> knows Sonoma County plumbing.</p>
            </a>
          </div>
          <div>
            <a href="/marin-county-plumbing/">
              <h3>Marin County Plumbing</h3>
              <p>San Rafael, Novato, Mill Valley, and throughout Marin. <CompanyName full /> understands the unique plumbing needs of Marin homes.</p>
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- CTA Section -->
    <section class="cta">
      <div>
        <h2>You Need a Plumber Call <CompanyName full /></h2>
        <p>Contact <CompanyName full /> now for fast, reliable service in Sonoma County and Marin County</p>
        <a href="/contact-us/">
          Get in Touch
        </a>
    </div>
  </section>
</BaseLayout>
