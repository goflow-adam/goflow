---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/pages/reserve.css';
import { Clock, ShieldCheck, DollarSign, Wrench, AlertTriangle, CheckCircle, ArrowRight } from '@lucide/astro';
import { createFAQSchema } from '../../lib/schema/factories';

const faqs = [
  {
    question: 'What if my water heater lasts longer than expected?',
    answer: 'Your reservation is valid for 10 years. Your unit will be waiting whenever you need it within that window.'
  },
  {
    question: 'Is installing a pre-2027 gas water heater legal after the ban takes effect?',
    answer: 'Yes. The BAAQMD Rule 9-6 applies to water heaters manufactured after January 1, 2027. Units manufactured before that date can still be sold and installed.'
  },
  {
    question: "What's included in the $999 reservation fee?",
    answer: 'Your $999 covers the water heater unit, storage at our facility, and a guaranteed $3,999 base installation price. The initial assessment identifies if any additional work (code upgrades, venting, etc.) would be needed.'
  },
  {
    question: 'What if I sell my home?',
    answer: 'Your reservation can be transferred to the new homeowner for a $150 transfer fee—potentially adding value to your home sale.'
  },
  {
    question: 'What brands of water heaters do you offer?',
    answer: 'We work with trusted manufacturers including Bradford White and Rheem. During your assessment, we\'ll recommend the best fit for your home.'
  },
  {
    question: 'Can I cancel my water heater reservation?',
    answer: 'Yes. Cancel within 3 business days for a full refund. After that, you\'ll receive a 50% refund ($499.50). You can also take possession of your unit for a $499.50 fee.'
  },
  {
    question: 'What if regulations change and gas water heaters become illegal to install?',
    answer: 'If installation becomes infeasible due to regulatory changes, your $999 program fee converts to a credit toward a code-compliant installation.'
  },
  {
    question: "What if GoFlow can't procure a water heater for me?",
    answer: 'If we\'re unable to procure a compliant unit despite reasonable efforts, you receive a full refund of your $999 program fee.'
  }
];

const faqSchema = await createFAQSchema(faqs, 'https://goflow.plumbing/reserve/');
---

<BaseLayout
  title="Reserve Your Gas Water Heater Before the 2027 Ban | GoFlow Plumbing"
  description="Lock in today's prices and secure a compliant gas water heater before the Bay Area ban takes effect. GoFlow's Replacement Reservation Plan helps you avoid $5,000-$10,000+ in future costs."
  schema={faqSchema}
>
  <article class="reserve-page">
    <!-- Hero Section -->
    <section class="reserve-hero">
      <div class="hero-content">
        <p class="hero-eyebrow">GoFlow Replacement Reservation Plan</p>
        <h1>Secure Your Gas Water Heater<br />Before the 2027 Ban</h1>
        <p class="hero-subtitle">
          Starting January 1, 2027, new gas water heaters will be banned in the Bay Area. 
          Reserve yours now for <strong>$999</strong>—install it when you need it.
        </p>
        <div class="hero-cta">
          <a href="#reserve-form" class="btn btn-primary">Reserve Now</a>
          <a href="#how-it-works" class="btn btn-secondary">Learn How It Works</a>
        </div>
      </div>
    </section>

    <!-- The Problem Section -->
    <section class="problem-section">
      <div class="section-content">
        <h2>The Problem: A $5,000–$10,000+ Surprise Is Coming</h2>
        <p class="section-intro">
          The <a href="https://www.baaqmd.gov/rules-and-compliance/rules/reg-9-rule-6-nitrogen-oxides-emissions-from-natural-gasfired-water-heaters" target="_blank" rel="noopener noreferrer">Bay Area Air Quality Management District (BAAQMD Rule 9-6)</a> has mandated that all residential gas water heaters 
          manufactured after January 1, 2027 must meet zero-NOx emission standards. In practical terms: 
          <strong>traditional gas water heaters will no longer be available.</strong>
        </p>
        
        <div class="comparison-grid">
          <div class="comparison-card today">
            <h3>With Reservation Plan</h3>
            <div class="price">$999 + $3,999</div>
            <div class="price-note">reservation + installation</div>
            <ul>
              <li><CheckCircle class="icon check" /> Simple gas-to-gas swap</li>
              <li><CheckCircle class="icon check" /> Same-day installation</li>
              <li><CheckCircle class="icon check" /> No electrical work needed</li>
              <li><CheckCircle class="icon check" /> Familiar technology</li>
            </ul>
          </div>
          <div class="comparison-card future">
            <h3>Without Reservation (After 2027)</h3>
            <div class="price warning">$8,000–$15,000+</div>
            <div class="price-note warning">heat pump conversion required</div>
            <ul>
              <li><AlertTriangle class="icon warning" /> Heat pump or electric required</li>
              <li><AlertTriangle class="icon warning" /> Electrical panel upgrades likely</li>
              <li><AlertTriangle class="icon warning" /> Multi-day installation</li>
              <li><AlertTriangle class="icon warning" /> Space modifications may be needed</li>
            </ul>
          </div>
        </div>

        <p class="learn-more">
          <a href="/articles/bay-area-gas-water-heater-ban/">
            Read our complete guide to the Bay Area Gas Water Heater Ban <ArrowRight class="inline-icon" />
          </a>
        </p>
      </div>
    </section>

    <!-- The Solution Section -->
    <section class="solution-section" id="how-it-works">
      <div class="section-content">
        <h2>The Solution: Reserve Now, Install Later</h2>
        <p class="section-intro">
          For a <strong>$999 program fee</strong>, the GoFlow Replacement Reservation Plan secures a compliant, 
          pre-2027 gas water heater in your name—with a guaranteed <strong>$3,999 base installation price</strong> 
          when you're ready.
        </p>

        <div class="benefits-grid">
          <div class="benefit-card">
            <DollarSign class="benefit-icon" />
            <h3>Lock In Today's Prices</h3>
            <p>
              Your $999 reservation secures a $3,999 base installation price—a total under $5,000 
              compared to $8,000–$15,000+ for a post-2027 heat pump conversion.
            </p>
          </div>
          <div class="benefit-card">
            <Clock class="benefit-icon" />
            <h3>10-Year Flexibility</h3>
            <p>
              Your reservation is valid for 10 years. Your water heater is stored at our facility, 
              ready whenever you need it—no scrambling, no surprises.
            </p>
          </div>
          <div class="benefit-card">
            <Wrench class="benefit-icon" />
            <h3>Simple Like-for-Like Swap</h3>
            <p>
              Because your reserved unit is a traditional gas water heater, installation is straightforward—
              no electrical upgrades, no space modifications.
            </p>
          </div>
          <div class="benefit-card">
            <ShieldCheck class="benefit-icon" />
            <h3>Protected Investment</h3>
            <p>
              Selling your home? Transfer your reservation for $150. Regulations change? 
              Your $999 converts to credit toward a compliant installation.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works Section -->
    <section class="process-section">
      <div class="section-content">
        <h2>How the Reservation Plan Works</h2>
        
        <div class="process-steps">
          <div class="process-step">
            <div class="step-number">1</div>
            <div class="step-content">
              <h3>Schedule Your Assessment</h3>
              <p>
                We visit your home to evaluate your current water heater setup, verify installation 
                requirements, and confirm program eligibility.
              </p>
            </div>
          </div>
          <div class="process-step">
            <div class="step-number">2</div>
            <div class="step-content">
              <h3>Pay Your $999 Reservation Fee</h3>
              <p>
                Lock in your reservation. We purchase a pre-2027 gas water heater, assign it to you, 
                and provide photo documentation of your unit.
              </p>
            </div>
          </div>
          <div class="process-step">
            <div class="step-number">3</div>
            <div class="step-content">
              <h3>We Store It Safely</h3>
              <p>
                Your water heater is stored in our facility, ready and waiting. You don't need 
                to find space in your garage.
              </p>
            </div>
          </div>
          <div class="process-step">
            <div class="step-number">4</div>
            <div class="step-content">
              <h3>Install at $3,999 When Ready</h3>
              <p>
                When your current water heater fails—or whenever you're ready—we install your 
                reserved unit at the guaranteed base price of $3,999.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Who Is This For Section -->
    <section class="audience-section">
      <div class="section-content">
        <h2>Is This Right for You?</h2>
        <p class="section-intro">
          The Replacement Reservation Plan is ideal for homeowners who:
        </p>
        
        <ul class="audience-list">
          <li>
            <CheckCircle class="icon" />
            <span>Have a water heater that's <strong>5+ years old</strong> and may need replacement in the next decade</span>
          </li>
          <li>
            <CheckCircle class="icon" />
            <span>Want to <strong>avoid the higher costs</strong> of a heat pump conversion</span>
          </li>
          <li>
            <CheckCircle class="icon" />
            <span>Prefer the <strong>simplicity of a gas water heater</strong> over new technology</span>
          </li>
          <li>
            <CheckCircle class="icon" />
            <span>Have <strong>electrical limitations</strong> that would make conversion expensive</span>
          </li>
          <li>
            <CheckCircle class="icon" />
            <span>Want <strong>predictable costs</strong> and a clear plan for the future</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="section-content">
        <h2>Common Questions</h2>
        
        <div class="faq-grid">
          <div class="faq-item">
            <h3>What if my water heater lasts longer than expected?</h3>
            <p>
              Your reservation is valid for 10 years. Your unit will be waiting whenever you need it 
              within that window.
            </p>
          </div>
          <div class="faq-item">
            <h3>Is this legal after the ban takes effect?</h3>
            <p>
              Yes. The rule applies to water heaters <em>manufactured</em> after January 1, 2027. 
              Units manufactured before that date can still be sold and installed.
            </p>
          </div>
          <div class="faq-item">
            <h3>What's included in the $999 reservation?</h3>
            <p>
              Your $999 covers the water heater unit, storage at our facility, and a guaranteed 
              $3,999 base installation price. The initial assessment identifies if any additional 
              work (code upgrades, venting, etc.) would be needed.
            </p>
          </div>
          <div class="faq-item">
            <h3>What if I sell my home?</h3>
            <p>
              Your reservation can be transferred to the new homeowner for a $150 transfer fee—
              potentially adding value to your home sale.
            </p>
          </div>
          <div class="faq-item">
            <h3>What brands do you offer?</h3>
            <p>
              We work with trusted manufacturers including Bradford White and Rheem. During your 
              assessment, we'll recommend the best fit for your home.
            </p>
          </div>
          <div class="faq-item">
            <h3>Can I cancel my reservation?</h3>
            <p>
              Yes. Cancel within 3 business days for a full refund. After that, you'll receive 
              a 50% refund ($499.50). You can also take possession of your unit for a $499.50 fee.
            </p>
          </div>
          <div class="faq-item">
            <h3>What if regulations change and gas becomes illegal?</h3>
            <p>
              If installation becomes infeasible due to regulatory changes, your $999 program fee 
              converts to a credit toward a code-compliant installation.
            </p>
          </div>
          <div class="faq-item">
            <h3>What if you can't get me a water heater?</h3>
            <p>
              If we're unable to procure a compliant unit despite reasonable efforts, you receive 
              a full refund of your $999 program fee.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA / Form Section -->
    <section class="cta-section" id="reserve-form">
      <div class="section-content">
        <div class="cta-grid">
          <div class="cta-info">
            <h2>Ready to Secure Your Water Heater?</h2>
            <p>
              Don't wait until your water heater fails after 2027 to discover your options have 
              changed. Take control now.
            </p>
            <div class="cta-benefits">
              <div class="cta-benefit">
                <CheckCircle class="icon" />
                <span>Free home assessment</span>
              </div>
              <div class="cta-benefit">
                <CheckCircle class="icon" />
                <span>No obligation to reserve</span>
              </div>
              <div class="cta-benefit">
                <CheckCircle class="icon" />
                <span>Transparent pricing</span>
              </div>
            </div>
            <div class="cta-phone">
              <p>Prefer to call?</p>
              <a href="tel:707-200-8350" class="phone-number">(707) 200-8350</a>
            </div>
          </div>
          
          <div class="cta-form-container">
            <h3>Schedule Your Free Assessment</h3>
            <form class="reserve-form" id="reserve-form">
              <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" required />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required />
              </div>
              <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" required />
              </div>
              <div class="form-group">
                <label for="address">Service Address</label>
                <input type="text" id="address" name="address" placeholder="Street address, City" required />
              </div>
              <div class="form-group">
                <label for="water-heater-age">Approximate Age of Current Water Heater</label>
                <select id="water-heater-age" name="water-heater-age">
                  <option value="">Select...</option>
                  <option value="0-5">0–5 years</option>
                  <option value="5-10">5–10 years</option>
                  <option value="10-15">10–15 years</option>
                  <option value="15+">15+ years</option>
                  <option value="unknown">Not sure</option>
                </select>
              </div>
              <div class="form-group">
                <label for="message">Questions or Comments (Optional)</label>
                <textarea id="message" name="message" rows="3"></textarea>
              </div>
              <input type="hidden" name="source" value="direct-mail-reserve" />
              <button type="submit" class="submit-btn">
                Schedule My Free Assessment
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Section -->
    <section class="trust-section">
      <div class="section-content">
        <h2>Why GoFlow?</h2>
        <div class="trust-grid">
          <div class="trust-item">
            <h3>3rd Generation Plumbers</h3>
            <p>Family expertise passed down through generations. We know plumbing.</p>
          </div>
          <div class="trust-item">
            <h3>Local to Sonoma & Marin</h3>
            <p>We live and work in your community. Your neighbors are our neighbors.</p>
          </div>
          <div class="trust-item">
            <h3>Licensed & Insured</h3>
            <p>California Contractors License #1150830 (C-36 Plumbing)</p>
          </div>
        </div>
        <p class="service-areas">
          Serving Santa Rosa, Petaluma, Novato, San Rafael, Healdsburg, Sonoma, Mill Valley, 
          and surrounding communities throughout Sonoma County and Marin County.
        </p>
      </div>
    </section>
  </article>
</BaseLayout>
